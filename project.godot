; Engine configuration file.
; Godot 4.6.x project for the top-down car prototype (Milestone 1).

config_version=5

[application]

config/name="Nitro Buggies"
config/description="Top-down 3D car racing — prototype milestone."
run/main_scene="res://scenes/LandingScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

Selection="*res://scripts/selection.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

common/physics_ticks_per_second=60

